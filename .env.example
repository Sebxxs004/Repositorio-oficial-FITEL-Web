# ============================================================
# Archivo de variables de entorno para producción en VPS
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env && nano .env
# IMPORTANTE: Nunca subas el .env real a Git
# ============================================================

# IP pública del servidor VPS
SERVER_IP=187.124.89.190

# Base de Datos MariaDB
DB_PASSWORD=CAMBIA_ESTA_CONTRASEÑA_DB
DB_ROOT_PASSWORD=CAMBIA_ESTA_CONTRASEÑA_ROOT

# JWT Secret (mínimo 32 caracteres, usa algo aleatorio)
# Generar con: openssl rand -base64 32
JWT_SECRET=CAMBIA_ESTE_SECRET_JWT_MUY_LARGO_Y_ALEATORIO

# Configuración de correo electrónico (para notificaciones y PQRs)
# Ejemplo con Gmail: usa una "Contraseña de aplicación" (no la contraseña normal)
MAIL_USERNAME=correo@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
MAIL_FROM=correo@gmail.com

# IPs permitidas para el panel de administración (separadas por coma)
# Deja vacío para permitir todas las IPs (no recomendado en producción)
ALLOWED_ADMIN_IPS=

# IPs permitidas para el servicio SOAP de la SIC (separadas por coma)
# Agrega la IP del servidor de la SIC y 127.0.0.1 para pruebas locales
FITEL_SIC_ALLOWED_IPS=127.0.0.1
